rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt, aiUsageCount
    //
    // Collection: offers
    // Fields: title, description, discount, expiryDate, active, imageUrl
    //
    // Collection: gallery
    // Fields: imageUrl, category, validated, uploadedBy, createdAt
    //
    // Collection: ai_requests
    // Fields: userId, inputImageUrl, resultImageUrl, hairstyleType, createdAt
    //
    // Collection: site_content
    // Fields: slogan, headline, aboutText, services
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "bochieng228@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidOffer(data) {
      return data.keys().hasAll(['title', 'active']) &&
             data.title is string && data.title.size() < 100 &&
             data.active is bool;
    }

    function isValidGalleryImage(data) {
      return data.keys().hasAll(['imageUrl', 'validated']) &&
             data.imageUrl is string &&
             data.validated is bool;
    }

    function isValidAIRequest(data) {
      return data.keys().hasAll(['userId', 'inputImageUrl', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.inputImageUrl is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'customer' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin() && isValidOffer(request.resource.data);
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidGalleryImage(request.resource.data) &&
                    (isAdmin() || (!request.resource.data.validated && request.resource.data.uploadedBy == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    match /ai_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidAIRequest(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /site_content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
